@using TimeTracker.FE.Web.Components.Interops
@inject CssLoaderInterop Css

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Css.LoadCssBatch(
                "styles/MButton.css",
                "styles/MCombobox.css",
                "styles/MRadioGroup.css",
                "styles/MTable.css",
                "styles/MTabs.css",
                "styles/MTextArea.css",
                "styles/MTextBox.css",
                "styles/MToast.css",
                "styles/MToastComponent.css"
            );
        }
    }
}